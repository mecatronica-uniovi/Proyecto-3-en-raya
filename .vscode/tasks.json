{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Compilar todo el proyecto",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "main.cpp",
                "Fdt.cpp",
                "reg.cpp",
                "-o",
                "${fileDirname}\\main.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compila main.cpp junto con otros archivos fuente"
        }
    ],
    "version": "2.0.0"
}
